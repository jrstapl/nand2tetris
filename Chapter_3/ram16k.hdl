CHIP RAM16K {
    IN in[16], load, address[14];
    OUT out[16];

    PARTS:

    DMux4Way(in=load, sel=address[0..1], a=r1, b=r2, c=r3, d=r4);
    RAM4K(in=in, load=r1, address=address[2..13], out=reg1);
    RAM4K(in=in, load=r2, address=address[2..13], out=reg2);
    RAM4K(in=in, load=r3, address=address[2..13], out=reg3);
    RAM4K(in=in, load=r4, address=address[2..13], out=reg4);

    Mux4Way16(a= reg1, b=reg2 , c=reg3 , d=reg4 , sel=address[0..1], out=out );

}
