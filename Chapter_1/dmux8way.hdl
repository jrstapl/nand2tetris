CHIP DMux8Way {
    IN in, sel[3];
    OUT a, b, c, d, e, f, g, h;

    PARTS:
    /*Layer 1
    A | B | C | D
    E | F | G | H
    */
    DMux4Way(in=in,sel=sel[1..2],a=ab,b=cd,c=ef,d=gh);

    /*Layer 2
    A | B
    C | D
    E | F
    G | H*/
    DMux(in=ab,sel=sel[0],a=a,b=b);
    DMux(in=cd,sel=sel[0],a=c,b=d);
    DMux(in=ef,sel=sel[0],a=e,b=f);
    DMux(in=gh,sel=sel[0],a=g,b=h);


}
